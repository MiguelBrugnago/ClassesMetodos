@model List<Model.Customer>
<table>
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th></th>
    </tr>
    </thead>
<tbody>
    @foreach(var customer in Model)
    {
        <tr>
            <td>@customer.Id</td>
            <td>@customer.FirstName</td>
            <td>@customer.Email</td>
            </tr>

    }
   </table> 